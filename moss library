			})
			createUI("UICorner", { 
				Parent = container
			})
			local optionHolder = createUI("Frame", {
				Size = UDim2.new(1, 0, 0, 0),
				BackgroundColor3 = Color3.fromRGB(60, 60, 60),
				Parent = container
			})
			createUI("UICorner", { Parent = optionHolder })

			local layout = createUI("UIListLayout", {
				Padding = UDim.new(0, 4),
				SortOrder = Enum.SortOrder.LayoutOrder,
				Parent = optionHolder
			})

			local function updateCanvas()
				local newHeight = layout.AbsoluteContentSize.Y + 10
				TweenService:Create(container, TweenInfo.new(0.2), {
					Size = dropdown.FrameOpen and UDim2.new(1, 0, 0, newHeight) or UDim2.new(1, 0, 0, 0)
				}):Play()
			end

			local function updateOptionVisual(button, isSelected)
				if isSelected then
					button.BackgroundColor3 = selectedTheme.Accent or Color3.fromRGB(0, 170, 255)
					button.TextColor3 = Color3.new(1,1,1)
				else
					button.BackgroundColor3 = selectedTheme.Buttons
					button.TextColor3 = selectedTheme.TextColor
				end
				if multi then
					btn.Text = opts.Text .. " (" .. tostring(#dropdown.Selected) .. ")"
				else
					btn.Text = opts.Text .. ": " .. tostring(dropdown.Selected[1] or "None")
				end
			end

			local function UpdateOptionVisual()
				for _, child in ipairs(optionHolder:GetChildren()) do
					if child:IsA("TextButton") then
						local isSelected = table.find(dropdown.Selected, child.Text)
						updateOptionVisual(child, isSelected)
					end
				end

				if multi then
					btn.Text = opts.Text .. " (" .. tostring(#dropdown.Selected) .. ")"
				else
					btn.Text = opts.Text .. ": " .. tostring(dropdown.Selected[1] or "None")
				end
			end

			local function createOptions(optionList)
				for _, child in ipairs(optionHolder:GetChildren()) do
					if child:IsA("TextButton") then
						child:Destroy()
					end
				end

				for _, option in ipairs(optionList) do
					local optBtn = createUI("TextButton", {
						Text = option,
						TextColor3 = selectedTheme.TextColor,
						Font = Enum.Font.Gotham,
						TextSize = 14,
						BackgroundColor3 = selectedTheme.Buttons,
						Size = UDim2.new(1, 0, 0, 28),
						Parent = optionHolder
					})
					createUI("UICorner", { Parent = optBtn })
					updateOptionVisual(optBtn, table.find(dropdown.Selected, option))
					optBtn.MouseButton1Click:Connect(function()
						if multi then
							if table.find(dropdown.Selected, option) then
								table.remove(dropdown.Selected, table.find(dropdown.Selected, option))
							else
								table.insert(dropdown.Selected, option)
							end
						else
							dropdown.Selected = {option}
							dropdown.FrameOpen = false
							updateCanvas()
						end


						for _, child in ipairs(optionHolder:GetChildren()) do
							if child:IsA("TextButton") then
								local isSelected = table.find(dropdown.Selected, child.Text)
								updateOptionVisual(child, isSelected)
							end
						end

						if settings1 and settings1.Data and settings1.Data.EnableSavingData then
							tab.dropdownValue = tab.dropdownValue or {}
							tab.dropdownValue[flag] = dropdown.Selected
							SetFlag(tab.name, flag, dropdown.Selected)
						end


						if opts.Callback then 
							opts.Callback(option, dropdown.Selected) 
						end
					end)
				end
			end

			createOptions(dropdown.Options)

			btn.MouseButton1Click:Connect(function()
				dropdown.FrameOpen = not dropdown.FrameOpen
				updateCanvas()
			end)

			updateCanvas()
			UpdateOptionVisual()

			function dropdown:Refresh(newOptions)
				dropdown.Options = newOptions
				dropdown.Selected = {}
				UpdateOptionVisual()
				createOptions(newOptions)
			end

			function dropdown:Select(value)
				local changed = false

				if typeof(value) == "table" then
					if multi then
						for _, val in ipairs(value) do
							if not table.find(dropdown.Options, val) then
								warn("Option '" .. tostring(val) .. "' non trouvée dans le dropdown.")
								continue
							end
							if not table.find(dropdown.Selected, val) then
								table.insert(dropdown.Selected, val)
								changed = true
							end
						end
					else
						local val = value[1]
						if not table.find(dropdown.Options, val) then
							warn("Option '" .. tostring(val) .. "' non trouvée dans le dropdown.")
							return
						end
						if dropdown.Selected[1] ~= val or #dropdown.Selected > 1 then
							dropdown.Selected = {val}
							changed = true
						end
						dropdown.FrameOpen = false
						updateCanvas()
					end
				else
					if not table.find(dropdown.Options, value) then
						warn("Option '" .. tostring(value) .. "' non trouvée dans le dropdown.")
						return
					end

					if multi then
						if not table.find(dropdown.Selected, value) then
							table.insert(dropdown.Selected, value)
							changed = true
						end
					else
						if dropdown.Selected[1] ~= value or #dropdown.Selected > 1 then
							dropdown.Selected = {value}
							changed = true
						end
						dropdown.FrameOpen = false
						updateCanvas()
					end
				end

				if changed then

					if settings1 and settings1.Data and settings1.Data.EnableSavingData then
						tab.dropdownValue = tab.dropdownValue or {}
						tab.dropdownValue[flag] = dropdown.Selected
						SetFlag(tab.name, flag, dropdown.Selected)
					end

					UpdateOptionVisual()

					if opts.Callback then
						local selectedCopy = table.clone(dropdown.Selected)
						local firstValue = (typeof(value) == "table" and value[1]) or value
						opts.Callback(firstValue, selectedCopy)
					end


				end
			end

			function dropdown:ChangeTheme(ThemesName)
				btn.BackgroundColor3 = selectedTheme.Buttons
				btn.TextColor3 = selectedTheme.TextColor
				createOptions(dropdown.Options)
			end
			tab.dropdowns[flag] = dropdown 
			return dropdown
		end
			if #window.tabs == 1 then
				if tab.content then
				tab.content.Visible = true
				end
			end
		return tab
	end

	local UIS = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")

	local dragging = false
	local dragStart
	local startPos

	local resizing = false
	local resizeStart
	local startSize
	local resizeDir = {X = false, Y = false}
	local RESIZE_MARGIN = 6

	local Resizing = false
	local oldMouseIcon = ""

	function library:CanResize(booleen)
		dragging = false
		Resizing = booleen
	end

	mainFrame.InputBegan:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then 
			local mousePos = UIS:GetMouseLocation()
			local absPos = mainFrame.AbsolutePosition
			local absSize = mainFrame.AbsoluteSize
			if input.UserInputType ~= Enum.UserInputType.Touch then
				local onRight = math.abs(mousePos.X - (absPos.X + absSize.X)) <= RESIZE_MARGIN
				local onLeft = math.abs(mousePos.X - absPos.X) <= RESIZE_MARGIN

				local onBottom = math.abs(mousePos.Y - (absPos.Y + absSize.Y)) <= RESIZE_MARGIN
				local onTop = math.abs(mousePos.Y - absPos.Y) <= RESIZE_MARGIN

				if onRight or onLeft or onBottom or onTop then
					resizing = true
					dragging = false

					resizeDir = {
						X = onRight or onLeft,
						Y = onBottom or onTop
					}

					resizeStart = mousePos
					startSize = mainFrame.Size

					return
				end
			end
			if Resizing then return end

			dragging = true
			dragStart = mousePos
			startPos = mainFrame.Position
		end
	end)
	mainFrame.InputEnded:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then 
			dragging = false
			resizing = false
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then 
			dragging = false
			resizing = false
		end
	end)

	local DeltaTime = 0

	RenderConnection = RunService.RenderStepped:Connect(function(dt)
		DeltaTime = DeltaTime + (dt - DeltaTime) * 0.1
		local fps = math.floor(1 / DeltaTime)
		FPS = fps
		FpsCounterLabel.Text = "Fps: "..FPS

		local mousePos = UIS:GetMouseLocation()
		local absPos = mainFrame.AbsolutePosition
		local absSize = mainFrame.AbsoluteSize

		local onRight = math.abs(mousePos.X - (absPos.X + absSize.X)) <= RESIZE_MARGIN
		local onBottom = math.abs(mousePos.Y - (absPos.Y + absSize.Y)) <= RESIZE_MARGIN

		if resizing then
			if not mainFrame.Visible then
				resizing = false
				dragging = false
				return
			end
			local delta = mousePos - resizeStart

			local newX = startSize.X.Offset
			local newY = startSize.Y.Offset

			if resizeDir.X then
				newX = math.clamp(newX + delta.X, 200, 1000)
			end

			if resizeDir.Y then
				newY = math.clamp(newY + delta.Y, 150, 800)
			end

			mainFrame.Size = UDim2.new(
				startSize.X.Scale,
				newX,
				startSize.Y.Scale,
				newY
			)

			CurrentSizePC = mainFrame.Size
			animOpenPC = TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Size = CurrentSizePC;
				Position = UDim2.new(0.5, 0, 0.5, 0);
			})
		end

		if dragging then
			if not mainFrame.Visible then
				dragging = false
				Resizing = false
				return
			end

			local delta = mousePos - dragStart

			mainFrame.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end)

	gui.Destroying:Connect(function()
		RenderConnection:Disconnect()
		RenderConnection = nil
	end)
end

