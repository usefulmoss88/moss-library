	local function EncodeValue(v)
		local t = typeof(v)

		if t == "Color3" then
			return { __type = "Color3", R = v.R, G = v.G, B = v.B }

		elseif t == "Vector2" then
			return { __type = "Vector2", X = v.X, Y = v.Y }

		elseif t == "Vector3" then
			return { __type = "Vector3", X = v.X, Y = v.Y, Z = v.Z }

		elseif t == "UDim2" then
			return {
				__type = "UDim2",
				XScale = v.X.Scale,
				XOffset = v.X.Offset,
				YScale = v.Y.Scale,
				YOffset = v.Y.Offset
			}

		elseif t == "table" then
			local newTable = {}

			for k, val in pairs(v) do
				newTable[k] = EncodeValue(val)
			end

			return {
				__type = "table",
				value = newTable
			}
		end

		return v
	end

	local function DecodeValue(v)
		if type(v) ~= "table" or not v.__type then
			return v
		end

		if v.__type == "Color3" then
			return Color3.new(v.R, v.G, v.B)

		elseif v.__type == "Vector2" then
			return Vector2.new(v.X, v.Y)

		elseif v.__type == "Vector3" then
			return Vector3.new(v.X, v.Y, v.Z)

		elseif v.__type == "UDim2" then
			return UDim2.new(v.XScale, v.XOffset, v.YScale, v.YOffset)

		elseif v.__type == "table" then
			local t = {}
			for k, val in pairs(v.value or {}) do
				t[k] = DecodeValue(val)
			end
			return t
		end

		return v
	end

	local function GetFlagKey(tabName, elementName)
		return tabName .. "_" .. elementName
	end

	local function SaveData()
		local success, err = pcall(function()

			if not isfolder(FolderName) then
				makefolder(FolderName)
			end

			local json = HttpService:JSONEncode(flags)
			writefile(fullPath, json)

		end)

		if not success then
			warn("[SaveSystem] Save error:", err)
		end
	end


	local function SetFlag(tabName, name, value)
		local key = GetFlagKey(tabName, name)

		flags[key] = {
			value = EncodeValue(value)
		}

		SaveData()
	end

	library.SetFlag = SetFlag


	local function GetFlag(tabName, name)
		local key = GetFlagKey(tabName, name)
		local data = flags[key]

		if not data then return nil end

		return DecodeValue(data.value)
	end

	local function applyFlagsToTab(tab)
		for key, data in pairs(flags) do

			local prefix = tab.name .. "_"

			if string.sub(key, 1, #prefix) == prefix then
				local name = string.sub(key, #prefix + 1)

				local value = DecodeValue(data.value)

				if tab.sliders[name] then
					pcall(function()
						tab.sliders[name]:SetValue(value)
						tab.SlidersValue[name] = value
					end)
				end

				if tab.texts[name] then
					pcall(function()
						tab.texts[name]:Set({value})
					end)
				end

				if tab.sections[name] then
					pcall(function()
						tab.sections[name]:Set({value})
					end)
				end

				if tab.paragraphs[name] then
					pcall(function()
						tab.paragraphs[name]:Set(value)
					end)
				end

				if tab.ColorPicker[name] then
					pcall(function()
						tab.ColorPicker[name]:Set(value)
						tab.ColorPickerValue[name] = value
					end)
				end

				if tab.textboxes[name] then
					pcall(function()
						tab.textboxes[name]:SetText(value)
						tab.textboxesText[name] = value
					end)
				end

				if tab.dropdowns[name] then
					pcall(function()
						tab.dropdowns[name]:Select(value)
						tab.dropdownValue[name] = value
					end)
				end

				if tab.toggles[name] then
					pcall(function()
						tab.toggles[name]:Set(value)
						tab.TogglesValue[name] = value
					end)
				end

				task.wait(0.02)
			end
		end
	end

