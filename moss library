		function tab:AddDropdown(opts)
			local flag = opts.Flag or opts.Name or "Dropdown"
			local multi = opts.MultiSelect or false
			local dropdown = {}
			local Default = opts.Default
			dropdown.Selected = {}
			dropdown.Options = opts.Options or {}
			dropdown.FrameOpen = false

			if Default ~= nil and Default ~= "" then
				if multi then
					if typeof(Default) == "table" then
						dropdown.Selected = table.clone(Default)
					else
						dropdown.Selected = {Default}
					end
				else
					if typeof(Default) == "table" then
						dropdown.Selected = {Default[1]}
					else
						dropdown.Selected = {Default}
					end
				end
			end
			tab.dropdowns = tab.dropdowns or {}
